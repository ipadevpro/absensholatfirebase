rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isGuru() {
      return isAuthenticated() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCoordinator() {
      return isAuthenticated() && exists(/databases/$(database)/documents/coordinators/$(request.auth.uid));
    }

    match /students/{studentId} {
      allow read: if isGuru() || isCoordinator();
      allow write: if isGuru();
    }

    match /coordinators/{coordinatorId} {
      allow read: if isGuru() || (isAuthenticated() && request.auth.uid == coordinatorId);
      allow write: if isGuru();
    }

    match /attendance/{attendanceId} {
      allow read: if isGuru() || isCoordinator();
      allow write: if isGuru() || isCoordinator();
    }
    
    match /admins/{adminId} {
      allow read: if isGuru();
      allow write: if false;
    }
  }
}
